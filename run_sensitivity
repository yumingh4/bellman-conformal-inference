        plt.tight_layout()
        fname = f'{save_path}{dataset}_T_sensitivity.png'
        plt.savefig(fname, dpi=300, bbox_inches='tight')
        plt.close()
        print(f"  ✓ Saved: {fname}")


def analyze_variance_coverage_tradeoff(dataset, task='rtfc', c_values=None):
    """
    Generate Pareto frontier showing variance-coverage tradeoff
    
    Varies c to show the fundamental tradeoff between:
    - Tight coverage (low variance) → potentially longer intervals
    - Loose coverage (high variance) → potentially shorter intervals
    """
    if c_values is None:
        c_values = np.logspace(-3, 0, 30)  # Dense sampling for smooth curve
    
    print(f"\n{'='*70}")
    print(f"VARIANCE-COVERAGE TRADEOFF: {dataset}")
    print(f"{'='*70}")
    
    # Run c-sensitivity to get data points
    df_tight = analyze_c_sensitivity(dataset, task, c_values, setting='tight')
    df_loose = analyze_c_sensitivity(dataset, task, c_values, setting='loose')
    
    # Create tradeoff plot
    fig, ax = plt.subplots(figsize=(10, 8))
    
    # Plot Pareto frontiers
    ax.scatter(df_tight['std'], df_tight['length'], 
              c=df_tight['c'], cmap='Reds', s=100, 
              label='Tight (99th percentile)', alpha=0.7, edgecolors='black')
    ax.scatter(df_loose['std'], df_loose['length'],
              c=df_loose['c'], cmap='Blues', s=100,
              label='Loose (95th percentile)', alpha=0.7, edgecolors='black')
    
    # Annotate selected points
    for setting, df, color in [('tight', df_tight, 'red'), ('loose', df_loose, 'blue')]:
        # Mark c=0.01, 0.1, 1.0
        for c_mark in [0.01, 0.1, 1.0]:
            row = df.iloc[(df['c'] - c_mark).abs().argsort()[:1]]
            ax.annotate(f'c={c_mark}', 
                       xy=(row['std'].values[0], row['length'].values[0]),
                       xytext=(10, 10), textcoords='offset points',
                       fontsize=10, color=color, fontweight='bold',
                       bbox=dict(boxstyle='round,pad=0.3', facecolor='white', alpha=0.7))
    
    ax.set_xlabel('Miscoverage Std (%)', fontsize=14, fontweight='bold')
    ax.set_ylabel('Average Interval Length', fontsize=14, fontweight='bold')
    ax.set_title(f'{dataset}: Variance-Coverage Tradeoff\n(Pareto Frontier)', 
                fontsize=16, fontweight='bold')
    ax.legend(fontsize=12, loc='best')
    ax.grid(alpha=0.3, linestyle=':')
    
    plt.tight_layout()
    fname = f'results/sensitivity/{dataset}_tradeoff.png'
    plt.savefig(fname, dpi=300, bbox_inches='tight')
    plt.close()
    print(f"  ✓ Saved: {fname}")
    
    return df_tight, df_loose


def run_all_sensitivity_analyses(datasets_by_task=None):
    """
    Run all sensitivity analyses for ALL tasks (returns, volatility, trends)
    
    Args:
        datasets_by_task: Dict mapping task to list of datasets
                         Default: {'rtfc': ['Amazon', 'AMD', 'Nvidia'],
                                  'vlfc': ['Amazon', 'AMD', 'Nvidia'],
                                  'trend': ['GoogleTrends']}
