    print(f"{'='*80}")
    
    for task in ['rtfc', 'vlfc', 'trend']:
        for dataset in datasets_by_task[task]:
            print(f"\n  Processing {task.upper()} - {dataset}...")
            df_tight, df_loose = analyze_variance_coverage_tradeoff(dataset, task)
            all_results['tradeoff'][f'{task}_{dataset}'] = {
