            df_loose = analyze_c_sensitivity(dataset, task, setting='loose')
            
            # Combine for plotting
            df_combined = pd.concat([df_tight, df_loose], ignore_index=True)
            all_results['c_sensitivity'][f'{task}_{dataset}'] = df_combined
    
    # Generate c-sensitivity plots
    print("\n  Generating c-sensitivity plots...")
    plot_c_sensitivity(all_results['c_sensitivity'])
    
    # ========================================================================
    # 2. T-SENSITIVITY (for Trends only, per PI's feedback)
    # ========================================================================
    print(f"\n{'='*80}")
    print("2. T-SENSITIVITY ANALYSIS (Trends)")
    print(f"{'='*80}")
    print("Note: Testing T ∈ {1, 3, 5, 7} per PI's confirmation")
    
