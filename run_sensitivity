results.append({
            'T': T,
            'miscoverage': miscov * 100,
            'std': np.sqrt(var) * 100,
            'length': length,
            'efficiency_gain': None  # Will compute relative to T=1
        })
    
    results_df = pd.DataFrame(results)
    
    # Compute efficiency gain relative to T=1 baseline
    if len(results_df) > 0:
        baseline_length = results_df[results_df['T'] == 1]['length'].values[0]
        results_df['efficiency_gain'] = (baseline_length - results_df['length']) / baseline_length * 100
    
    # Save results
    results_df.to_csv(f'results/sensitivity/{dataset}_T_sensitivity.csv', index=False)
    print(f"  ✓ Saved to results/sensitivity/{dataset}_T_sensitivity.csv")
    
    return results_df


def plot_T_sensitivity(results_dict, save_path='results/sensitivity/'):
    """
    Generate T-sensitivity plots for appendix
    
    Shows how increasing lookahead horizon affects coverage and efficiency
    """
    import os
    os.makedirs(save_path, exist_ok=True)
    
    for dataset, df_results in results_dict.items():
        fig, axs = plt.subplots(1, 3, figsize=(18, 5))
        
        # Plot 1: Miscoverage vs T
        axs[0].plot(df_results['T'], df_results['miscoverage'], 
                   marker='o', color='tomato', linewidth=2.5, markersize=8)
        axs[0].fill_between(df_results['T'], 
                           df_results['miscoverage'] - df_results['std'],
                           df_results['miscoverage'] + df_results['std'],
                           alpha=0.2, color='tomato')
        axs[0].axhline(10, color='black', linestyle='--', linewidth=1.5, label='Target')
        axs[0].set_xlabel('Horizon T (days)', fontsize=14, fontweight='bold')
        axs[0].set_ylabel('Miscoverage Rate (%)', fontsize=14, fontweight='bold')
        axs[0].set_title('Coverage Stability', fontsize=15, fontweight='bold')
        axs[0].grid(alpha=0.3, linestyle=':')
        axs[0].legend(fontsize=12)
        
        # Plot 2: Length vs T
        axs[1].plot(df_results['T'], df_results['length'],
                   marker='s', color='navy', linewidth=2.5, markersize=8)
        axs[1].set_xlabel('Horizon T (days)', fontsize=14, fontweight='bold')
        axs[1].set_ylabel('Average Interval Length', fontsize=14, fontweight='bold')
        axs[1].set_title('Prediction Efficiency', fontsize=15, fontweight='bold')
        axs[1].grid(alpha=0.3, linestyle=':')
        
        # Plot 3: Efficiency gain vs T
