def main():
    """Command-line interface for sensitivity analysis"""
    parser = argparse.ArgumentParser(description='Run sensitivity analyses for appendix')
    parser.add_argument('--all', action='store_true', help='Run all sensitivity analyses')
    parser.add_argument('--datasets', nargs='+', help='Specific datasets to analyze')
    parser.add_argument('--task', choices=['rtfc', 'vlfc', 'trend'], help='Specific task')
    parser.add_argument('--analysis', choices=['c', 'T', 'tradeoff'], help='Specific analysis type')
    
    args = parser.parse_args()
    
if args.all:
        # Run comprehensive analysis for all tasks and datasets
        run_all_sensitivity_analyses()
    
    elif args.analysis == 'c' and args.datasets and args.task:
        # Run c-sensitivity for specific datasets
        results = {}
        for dataset in args.datasets:
            df_tight = analyze_c_sensitivity(dataset, args.task, setting='tight')
            df_loose = analyze_c_sensitivity(dataset, args.task, setting='loose')
            df_combined = pd.concat([df_tight, df_loose], ignore_index=True)
            results[f'{args.task}_{dataset}'] = df_combined
        plot_c_sensitivity(results)
    
    elif args.analysis == 'T' and args.datasets:
        # Run T-sensitivity for specific datasets (trends only)
        results = {}
        for dataset in args.datasets:
            df_T = analyze_T_sensitivity(dataset, task='trend')
            results[f'trend_{dataset}'] = df_T
        plot_T_sensitivity(results)
    
    elif args.analysis == 'tradeoff' and args.datasets and args.task:
        # Run tradeoff analysis for specific datasets
        for dataset in args.datasets:
            analyze_variance_coverage_tradeoff(dataset, args.task)
    
    else:
        parser.print_help()
        print("\nExamples:")
        print("  python run_sensitivity_analysis.py --all")
        print("  python run_sensitivity_analysis.py --analysis c --task rtfc --datasets Amazon Nvidia")
        print("  python run_sensitivity_analysis.py --analysis T --datasets GoogleTrends")


if __name__ == '__main__':
    main()