    if datasets_by_task is None:
        datasets_by_task = {
            'rtfc': ['Amazon', 'AMD', 'Nvidia'],      # Returns
            'vlfc': ['Amazon', 'AMD', 'Nvidia'],      # Volatility
            'trend': ['GoogleTrends']                 # Trends
        }
    
    import os
    os.makedirs('results/sensitivity', exist_ok=True)
    
    print("\n" + "="*80)
    print("COMPREHENSIVE SENSITIVITY ANALYSIS FOR APPENDIX")
    print("="*80)
    print("\nTasks to analyze:")
    for task, datasets in datasets_by_task.items():
        print(f"  {task}: {', '.join(datasets)}")
    
    all_results = {
